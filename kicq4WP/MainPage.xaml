<Page
    x:Class="kicq4WP.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:kicq4WP"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="#FF0D1117">

    <Page.Resources>
        <local:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <Style x:Key="StatusItemStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontFamily" Value="Segoe WP"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="16,14,16,14"/>
            <Setter Property="Margin" Value="0"/>
        </Style>
    </Page.Resources>

    <Page.BottomAppBar>
        <CommandBar IsSticky="True" Opened="CommandBar_Opened" Background="#FF0078D7">
            <AppBarButton Icon="Account" Label="Статус" Click="StatusButton_Click" Foreground="White"/>
            <AppBarButton Icon="Contact"    Label="Акк. Инфо" Click="AcInfButton_Click" Foreground="White"/>
            <AppBarButton Icon="Cancel"     Label="Выйти" Click="LogoutButton_Click" Foreground="White"/>
            <CommandBar.SecondaryCommands>
                <AppBarButton Icon="Setting" Label="Настройки" Click="SettingsButton_Click"/>
                <AppBarButton Icon="Help"    Label="Справка"   Click="HelpButton_Click"/>
                <AppBarButton Icon="Cancel"  Label="Выход"     Click="ExitButton_Click"/>
            </CommandBar.SecondaryCommands>
        </CommandBar>
    </Page.BottomAppBar>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="56"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Шапка -->
        <Border Grid.Row="0" Background="#FF0078D7">
            <Grid Margin="8,0,8,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Image x:Name="OwnStatusIcon"
                       Grid.Column="0"
                       Source="/Assets/statuses/online.png"
                       Width="26" Height="26"
                       Margin="6,0,10,0"
                       VerticalAlignment="Center"/>

                <TextBlock x:Name="UinTextBlock"
                           Grid.Column="1"
                           FontSize="22"
                           FontWeight="SemiBold"
                           FontFamily="Segoe WP"
                           Foreground="White"
                           VerticalAlignment="Center"
                           Text="Offline"/>
            </Grid>
        </Border>

        <!-- Список контактов -->
        <ListView x:Name="ContactsListView"
                  Grid.Row="1"
                  ItemsSource="{Binding Contacts, Mode=OneWay}"
                  IsItemClickEnabled="True"
                  ItemClick="ContactsListView_ItemClick"
                  SelectionMode="None"
                  Background="Transparent"
                  Margin="0,2,0,0">
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    <Setter Property="Padding" Value="0"/>
                    <Setter Property="Margin" Value="0,0,0,1"/>
                    <Setter Property="Background" Value="Transparent"/>
                </Style>
            </ListView.ItemContainerStyle>
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Grid Background="#FF161B22" MinHeight="68">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="56"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Левая полоска акцентного цвета -->
                        <Rectangle Grid.Column="0"
                                   Width="3"
                                   HorizontalAlignment="Left"
                                   Fill="#FF0078D7"
                                   Visibility="{Binding HasUnread, Converter={StaticResource BoolToVisibilityConverter}}"/>

                        <!-- Статус иконка -->
                        <Image Grid.Column="0"
                               Source="{Binding StatusIcon}"
                               Width="34" Height="34"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>

                        <!-- Имя и UIN -->
                        <StackPanel Grid.Column="1"
                                    VerticalAlignment="Center"
                                    Margin="4,0,8,0">
                            <TextBlock Text="{Binding Name}"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       FontFamily="Segoe WP"
                                       Foreground="White"
                                       TextTrimming="CharacterEllipsis"/>
                            <TextBlock Text="{Binding Uin}"
                                       FontSize="13"
                                       FontFamily="Segoe WP"
                                       Foreground="#88FFFFFF"
                                       TextTrimming="CharacterEllipsis"
                                       Margin="0,2,0,0"/>
                        </StackPanel>

                        <!-- Счётчик непрочитанных -->
                        <Border Grid.Column="2"
                                Background="#FF0078D7"
                                MinWidth="26"
                                Height="26"
                                Margin="0,0,8,0"
                                VerticalAlignment="Center"
                                Visibility="{Binding HasUnread, Converter={StaticResource BoolToVisibilityConverter}}">
                            <TextBlock Text="{Binding UnreadCount}"
                                       FontSize="14"
                                       FontWeight="Bold"
                                       FontFamily="Segoe WP"
                                       Foreground="White"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Margin="4,0,4,0"/>
                        </Border>

                        <!-- Индикатор нового онлайна -->
                        <Ellipse Grid.Column="3"
                                 Width="10" Height="10"
                                 Fill="#FF00D4AA"
                                 VerticalAlignment="Center"
                                 Margin="0,0,14,0"
                                 Visibility="{Binding IsNewOnline, Converter={StaticResource BoolToVisibilityConverter}}"/>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <!-- Панель выбора статуса — поверх всего -->
        <Border x:Name="StatusPanel"
                Grid.Row="0"
                Grid.RowSpan="2"
                Background="#F0060A0F"
                Visibility="Collapsed"
                VerticalAlignment="Bottom">
            <StackPanel>
                <!-- Заголовок панели -->
                <Border Background="#FF0078D7" Padding="16,12,16,12">
                    <TextBlock Text="Выберите статус"
                               FontSize="16"
                               FontWeight="SemiBold"
                               FontFamily="Segoe WP"
                               Foreground="White"/>
                </Border>

                <Button Tag="00000000" Click="SetStatus_Click" Style="{StaticResource StatusItemStyle}">
                    <StackPanel Orientation="Horizontal">
                        <Image Source="/Assets/statuses/online.png" Width="28" Height="28" Margin="0,0,14,0"/>
                        <TextBlock Text="Онлайн" VerticalAlignment="Center" FontFamily="Segoe WP" FontSize="18" Foreground="White"/>
                    </StackPanel>
                </Button>

                <Button Tag="00000020" Click="SetStatus_Click" Style="{StaticResource StatusItemStyle}">
                    <StackPanel Orientation="Horizontal">
                        <Image Source="/Assets/statuses/f4c.png" Width="28" Height="28" Margin="0,0,14,0"/>
                        <TextBlock Text="Готов поболтать" VerticalAlignment="Center" FontFamily="Segoe WP" FontSize="18" Foreground="White"/>
                    </StackPanel>
                </Button>

                <Button Tag="00000001" Click="SetStatus_Click" Style="{StaticResource StatusItemStyle}">
                    <StackPanel Orientation="Horizontal">
                        <Image Source="/Assets/statuses/away.png" Width="28" Height="28" Margin="0,0,14,0"/>
                        <TextBlock Text="Отошел" VerticalAlignment="Center" FontFamily="Segoe WP" FontSize="18" Foreground="White"/>
                    </StackPanel>
                </Button>

                <Button Tag="00000002" Click="SetStatus_Click" Style="{StaticResource StatusItemStyle}">
                    <StackPanel Orientation="Horizontal">
                        <Image Source="/Assets/statuses/dnd.png" Width="28" Height="28" Margin="0,0,14,0"/>
                        <TextBlock Text="Не беспокоить" VerticalAlignment="Center" FontFamily="Segoe WP" FontSize="18" Foreground="White"/>
                    </StackPanel>
                </Button>

                <Button Tag="00000004" Click="SetStatus_Click" Style="{StaticResource StatusItemStyle}">
                    <StackPanel Orientation="Horizontal">
                        <Image Source="/Assets/statuses/na.png" Width="28" Height="28" Margin="0,0,14,0"/>
                        <TextBlock Text="Недоступен" VerticalAlignment="Center" FontFamily="Segoe WP" FontSize="18" Foreground="White"/>
                    </StackPanel>
                </Button>

                <Button Tag="00000010" Click="SetStatus_Click" Style="{StaticResource StatusItemStyle}">
                    <StackPanel Orientation="Horizontal">
                        <Image Source="/Assets/statuses/busy.png" Width="28" Height="28" Margin="0,0,14,0"/>
                        <TextBlock Text="Занят" VerticalAlignment="Center" FontFamily="Segoe WP" FontSize="18" Foreground="White"/>
                    </StackPanel>
                </Button>

                <Button Tag="00000100" Click="SetStatus_Click" Style="{StaticResource StatusItemStyle}">
                    <StackPanel Orientation="Horizontal">
                        <Image Source="/Assets/statuses/inv.png" Width="28" Height="28" Margin="0,0,14,0"/>
                        <TextBlock Text="Невидимый" VerticalAlignment="Center" FontFamily="Segoe WP" FontSize="18" Foreground="White"/>
                    </StackPanel>
                </Button>

                <!-- Кнопка закрыть -->
                <Button Click="StatusPanelClose_Click"
                        Background="#FF1A1A2E"
                        BorderThickness="0"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Center"
                        Padding="16,14,16,14">
                    <TextBlock Text="Отмена"
                               FontSize="16"
                               FontFamily="Segoe WP"
                               Foreground="#88FFFFFF"/>
                </Button>
            </StackPanel>
        </Border>
    </Grid>
</Page>
