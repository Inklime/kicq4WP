<Page
    x:Class="kicq4WP.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:kicq4WP"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid>
        <ComboBox x:Name="StatusComboBox" SelectedIndex="0" Margin="10,578,190,12">
            <ComboBoxItem Content="Онлайн" />
            <ComboBoxItem Content="Готов поболтать" />
            <ComboBoxItem Content="Отошел" />
            <ComboBoxItem Content="Недоступен" />
            <ComboBoxItem Content="Занят" />
            <ComboBoxItem Content="Не беспокоить" />
            <ComboBoxItem Content="Дома" />
            <ComboBoxItem Content="Работа" />
            <ComboBoxItem Content="Кушаю" />
            <ComboBoxItem Content="Депрессия" />
            <ComboBoxItem Content="Злой" />
            <ComboBoxItem Content="Невидимый" />
            <ComboBoxItem Content="Невидимый для всех" />
        </ComboBox>

        <Button x:Name="LogoutButton" Content="Выйти" Width="110" Height="24"
                HorizontalAlignment="Center" VerticalAlignment="Top"
                Margin="275,579,15,0"
                Background="Black" Foreground="White"
                Click="LogoutButton_Click"/>

        <ListView x:Name="ContactsListView" ItemClick="ContactsListView_ItemClick" 
                  IsItemClickEnabled="True" Margin="10,-2,10,72">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal">
                        <Image Source="{Binding StatusIcon}" Width="24" Height="24" Margin="5"/>
                        <TextBlock Text="{Binding Name}" FontSize="18" Foreground="White"/>
                    </StackPanel>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>
