<Page
    x:Class="kicq4WP.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:kicq4WP"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
    <Page.Resources>
        <local:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </Page.Resources>
    <Page.BottomAppBar>
        <CommandBar IsSticky="True" Opened="CommandBar_Opened">
            <!-- Кнопки в нижней панели -->
            <AppBarButton Icon="Cancel" Label="Выйти" Click="LogoutButton_Click"/>
            <AppBarButton Icon="Contact" Label="Акк. Инфо" Click="AcInfButton_Click"/>

            <CommandBar.SecondaryCommands>
                <AppBarButton Icon="Setting" Label="Настройки" Click="SettingsButton_Click"/>
                <AppBarButton Icon="Help" Label="Справка" Click="HelpButton_Click"/>
                <AppBarButton Icon="Cancel" Label="Выход" Click="ExitButton_Click"/>
            </CommandBar.SecondaryCommands>
        </CommandBar>
    </Page.BottomAppBar>

    <Grid>
        <TextBlock x:Name="UinTextBlock"
                   FontSize="30"
                   Foreground="White"
                   Margin="14,10,10,0"
                   VerticalAlignment="Top"
                   Text="Offline" />

        <ListView x:Name="ContactsListView"
                  IsItemClickEnabled="False"
                  Margin="10,60,10,10"
                  Background="Transparent"
                  BorderThickness="0"
                  SelectionMode="None">
            <ListView ItemsSource="{Binding Contacts, Mode=OneWay}" />

            <ListView.ItemTemplate>
                <DataTemplate>
                    <Button Click="ContactButton_Click"
                            Padding="10"
                            Margin="5"
                            Height="80"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Center"
                            Background="#44000000">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Image Source="{Binding StatusIcon}" Width="32" Height="32" Margin="0,0,10,0"/>
                            <TextBlock Text="{Binding Name}"
                                       FontSize="20"
                                       VerticalAlignment="Center"
                                       Foreground="White"/>
                            <TextBlock Text="&lt;&lt;&lt;&lt;" Margin="10,0,0,0"
                                       Foreground="Aqua"
                                       Visibility="{Binding IsNewOnline, Converter={StaticResource BoolToVisibilityConverter}}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>
