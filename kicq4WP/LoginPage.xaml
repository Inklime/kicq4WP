<Page
    x:Class="kicq4WP.LoginPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:kicq4WP"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="Black">

    <Page.BottomAppBar>
        <CommandBar IsSticky="True">
            <AppBarButton Icon="Permissions" Label="Войти" Click="LoginButton_Click"/>
            <AppBarButton Icon="Edit" Label="Регистр." Click="RegButton_Click"/>
            <AppBarButton Icon="People" Label="Контакты" Click="OnlOpenButton_Click"/>
            <CommandBar.SecondaryCommands>
                <AppBarButton Icon="Setting" Label="Настройки" Click="SettingsButton_Click"/>
                <AppBarButton Icon="Help" Label="Справка" Click="HelpButton_Click"/>
                <AppBarButton Icon="Cancel" Label="Выход" Click="ExitButton_Click"/>
            </CommandBar.SecondaryCommands>
        </CommandBar>
    </Page.BottomAppBar>

    <Grid Background="Black">
        <!-- Индикатор загрузки -->
        <Border x:Name="LoadingOverlay"
            Background="#80000000"
            Visibility="Collapsed"
            CornerRadius="5"
            Padding="20"
            VerticalAlignment="Center" Margin="10,431,10,22">
            <StackPanel Margin="18,0">
                <ProgressRing IsActive="True" Width="40" Height="40" Foreground="White"/>
                <TextBlock x:Name="StatusTextBlock" Text="Подключение..." Foreground="White" FontSize="16"
                       Margin="0,10,0,0" HorizontalAlignment="Center" Width="304"/>
            </StackPanel>
        </Border>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="20" HorizontalAlignment="Center" Width="341">
                <TextBlock Text="KICQ"
                       FontSize="36"
                       HorizontalAlignment="Center"
                       Foreground="White"
                       Margin="0,0,0,30"/>

                <TextBox x:Name="LoginTextBox"
                     PlaceholderText="Введите UIN"
                     Height="39"
                     Margin="0,0,0,20"
                     Background="White"/>

                <PasswordBox x:Name="PasswordBox"
                         PlaceholderText="Введите пароль"
                         Height="39"
                         Margin="0,0,0,20"
                         Background="White"/>

                <ComboBox x:Name="StatusComboBox"
                      SelectedIndex="0"
                      Margin="0,0,0,20">
                    <ComboBoxItem Content="Онлайн" />
                    <ComboBoxItem Content="Готов поболтать" />
                    <ComboBoxItem Content="Отошел" />
                    <ComboBoxItem Content="Недоступен" />
                    <ComboBoxItem Content="Занят" />
                    <ComboBoxItem Content="Не беспокоить" />
                    <ComboBoxItem Content="Дома" />
                    <ComboBoxItem Content="Работа" />
                    <ComboBoxItem Content="Кушаю" />
                    <ComboBoxItem Content="Депрессия" />
                    <ComboBoxItem Content="Злой" />
                    <ComboBoxItem Content="Невидимый" />
                    <ComboBoxItem Content="Невидимый для всех" />
                </ComboBox>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>