<Page
    x:Class="kicq4WP.LoginPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    FontFamily="{StaticResource PhoneFontFamilyNormal}"
    Foreground="{StaticResource PhoneForegroundBrush}"
    Background="Black">

    <Grid>
        <TextBlock Text="KICQ" FontSize="32" Foreground="White" 
                   HorizontalAlignment="Center" Margin="164,10,165,40"/>

        <TextBox x:Name="LoginTextBox" Width="300" Height="40"
                 PlaceholderText="Введите UIN"
                 HorizontalAlignment="Center" VerticalAlignment="Top"
                 Margin="50,155,50,0" Background="White"/>

        <TextBox x:Name="NicknameTextBox" 
         PlaceholderText="Ваш никнейм"
         Margin="50,101,50,0"/>

        <PasswordBox x:Name="PasswordBox" Width="300" Height="40"
                     PlaceholderText="Введите пароль"
                     HorizontalAlignment="Center" VerticalAlignment="Top"
                     Margin="50,211,50,0" Background="White"/>
        
        <Button x:Name="OnlOpenButton" Content="Только открыть" Width="200" Height="60"
                HorizontalAlignment="Center" VerticalAlignment="Top"
                Margin="95,405,105,0"
                Background="Black" Foreground="White"
                Click="OnlOpenButton_Click"/>

        <Button x:Name="LoginButton" Content="Войти" Width="200" Height="60"
                HorizontalAlignment="Center" VerticalAlignment="Top"
                Margin="95,466,105,0"
                Background="#045e01" Foreground="White"
                Click="LoginButton_Click"/>
        
        <ComboBox x:Name="StatusComboBox" SelectedIndex="0" Margin="50,276,50,314">
            <ComboBoxItem Content="Онлайн" />
            <ComboBoxItem Content="Готов поболтать" />
            <ComboBoxItem Content="Отошел" />
            <ComboBoxItem Content="Недоступен" />
            <ComboBoxItem Content="Занят" />
            <ComboBoxItem Content="Не беспокоить" />
            <ComboBoxItem Content="Дома" />
            <ComboBoxItem Content="Работа" />
            <ComboBoxItem Content="Кушаю" />
            <ComboBoxItem Content="Депрессия" />
            <ComboBoxItem Content="Злой" />
            <ComboBoxItem Content="Невидимый" />
            <ComboBoxItem Content="Невидимый для всех" />
        </ComboBox>
    </Grid>
</Page>