<Page
    x:Class="kicq4WP.ChatPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:kicq4WP"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="#FF0D0D0D">

    <Page.Resources>
        <local:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <Style x:Key="EmojiButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontFamily" Value="Segoe WP"/>
            <Setter Property="Width" Value="56"/>
            <Setter Property="Height" Value="44"/>
            <Setter Property="Margin" Value="2"/>
        </Style>
    </Page.Resources>

    <!-- Корневая сетка. Row 4 добавлена под панель ввода (превью ответа), -->
    <!-- а поверх всего лежит RootOverlayGrid для попапов (переименование и т.п.) -->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="56"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Шапка -->
        <Border Grid.Row="0" Background="{StaticResource PhoneAccentBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="52"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button x:ConnectionId='11' Grid.Column="0"
                                                
                        Background="Transparent"
                        BorderThickness="0"
                        Width="52" Height="56" RenderTransformOrigin="0.176,0.56" Margin="-58,1,0,-3">
                    <TextBlock Text="         " FontFamily="Segoe UI Symbol"
                               FontSize="22" Foreground="White"
                               VerticalAlignment="Center" HorizontalAlignment="Center" Width="79"/>
                </Button>

                <Image Grid.Column="1"
                       x:Name="ContactStatusIcon"
                       Width="26" Height="26"
                       VerticalAlignment="Center"
                       Margin="0,0,8,0"/>

                <StackPanel Grid.Column="2" VerticalAlignment="Center" Margin="0,0,8,0">
                    <TextBlock x:Name="ContactNameTextBlock"
                               Text="Контакт"
                               FontSize="20"
                               FontFamily="Segoe WP"
                               Foreground="White"
                               TextTrimming="CharacterEllipsis"/>
                    <TextBlock x:Name="ContactUinTextBlock"
                               Text=""
                               FontSize="12"
                               FontFamily="Segoe WP"
                               Foreground="#CCFFFFFF"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Список сообщений -->
        <ListView x:Name="MessagesList"
                  Grid.Row="1"
                  Background="#FF0D0D0D"
                  SelectionMode="None"
                  IsItemClickEnabled="False"
                  Padding="6,4,6,4">
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    <Setter Property="Padding" Value="0"/>
                    <Setter Property="Margin" Value="0,2,0,2"/>
                    <Setter Property="Background" Value="Transparent"/>
                </Style>
            </ListView.ItemContainerStyle>
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Grid MinHeight="10">
                        <!-- Входящее — слева -->
                        <Border x:ConnectionId='9' HorizontalAlignment="Left"
                                MaxWidth="280"
                                Background="#FF1E293B"
                                Padding="10,7,10,7"
                                Margin="0,0,50,0"
                                                               
                                Visibility="{Binding IsIncoming, Converter={StaticResource BoolToVisibilityConverter}}">
                            <StackPanel>
                                <TextBlock Text="{Binding SenderName}"
                                           FontSize="12"
                                           FontFamily="Segoe WP"
                                           Foreground="{StaticResource PhoneAccentBrush}"
                                           Margin="0,0,0,2"/>
                                <TextBlock Text="{Binding Text}"
                                           FontSize="17"
                                           FontFamily="Segoe WP"
                                           Foreground="White"
                                           TextWrapping="Wrap"/>
                                <TextBlock Text="{Binding Time}"
                                           FontSize="11"
                                           FontFamily="Segoe WP"
                                           Foreground="#88FFFFFF"
                                           HorizontalAlignment="Right"
                                           Margin="0,3,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- Исходящее — справа -->
                        <Border x:ConnectionId='10' HorizontalAlignment="Right"
                                MaxWidth="280"
                                Background="{StaticResource PhoneAccentBrush}"
                                Padding="10,7,10,7"
                                Margin="50,0,0,0"
                                                               
                                Visibility="{Binding IsOutgoing, Converter={StaticResource BoolToVisibilityConverter}}">
                            <StackPanel>
                                <TextBlock Text="{Binding Text}"
                                           FontSize="17"
                                           FontFamily="Segoe WP"
                                           Foreground="White"
                                           TextWrapping="Wrap"/>
                                <TextBlock Text="{Binding Time}"
                                           FontSize="11"
                                           FontFamily="Segoe WP"
                                           Foreground="#88FFFFFF"
                                           HorizontalAlignment="Right"
                                           Margin="0,3,0,0"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <!-- Панель эмодзи -->
        <Border x:Name="EmojiPanel"
                Grid.Row="2"
                Background="#FF1A1A1A"
                Padding="4"
                Visibility="Collapsed">
            <StackPanel>
                <StackPanel Orientation="Horizontal">
                    <Button x:ConnectionId='6' Content=":-)"                           Tag=":-)" Style="{StaticResource EmojiButtonStyle}"/>
                    <Button x:ConnectionId='7' Content=";-)"                           Tag=";-)" Style="{StaticResource EmojiButtonStyle}"/>
                    <Button x:ConnectionId='8' Content=":-("                           Tag=":-(" Style="{StaticResource EmojiButtonStyle}"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <Button x:ConnectionId='3' Content="8-)"                           Tag="8-)" Style="{StaticResource EmojiButtonStyle}"/>
                    <Button x:ConnectionId='4' Content=":-D"                           Tag=":-D" Style="{StaticResource EmojiButtonStyle}"/>
                    <Button x:ConnectionId='5' Content="]:->"                           Tag="]:->" Style="{StaticResource EmojiButtonStyle}"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Панель "Ответить на сообщение" -->
        <Border x:Name="ReplyPreviewPanel"
                Grid.Row="3"
                Background="#FF232323"
                BorderBrush="{StaticResource PhoneAccentBrush}"
                BorderThickness="4,0,0,0"
                Padding="8,4,8,4"
                Visibility="Collapsed">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="ReplyPreviewText"
                           Grid.Column="0"
                           Foreground="#CCFFFFFF"
                           FontSize="14"
                           FontFamily="Segoe WP"
                           TextTrimming="CharacterEllipsis"
                           MaxLines="1"
                           VerticalAlignment="Center"/>
                <Button x:ConnectionId='2' Grid.Column="1"
                        Content="✕"
                                                 
                        Background="Transparent"
                        BorderThickness="0"
                        Foreground="White"
                        FontSize="16"
                        Padding="10,4,4,4"/>
            </Grid>
        </Border>

        <!-- Панель ввода -->
        <Border Grid.Row="4" Background="#FF1A1A1A" Padding="6,6,6,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBox x:ConnectionId='1' x:Name="MessageTextBox"
                         Style="{StaticResource ChatInputStyle}"
                         PlaceholderText="Сообщение..."
                         Margin="4,0,10.333,0"
                         VerticalAlignment="Bottom"
                                                         
                         Grid.ColumnSpan="2"/>
            </Grid>
        </Border>

        <!-- Полноэкранный оверлей для попапов (переименование и т.п.) -->
        <!-- Grid.RowSpan="5" — растягиваем на всю страницу, чтобы не зависеть -->
        <!-- от Popup и его смещений на разных DPI -->
        <Grid x:Name="RootOverlayGrid"
              Grid.RowSpan="5"
              Background="#99000000"
              Visibility="Collapsed">
        </Grid>
    </Grid>

    <Page.BottomAppBar>
        <CommandBar Background="{StaticResource PhoneAccentBrush}">
            <AppBarButton x:ConnectionId='12' Icon="Send" Label="Отправить"                           Foreground="White"/>
            <AppBarButton x:ConnectionId='13' Icon="Emoji2" Label="Смайлики"                           Foreground="White"/>

            <CommandBar.SecondaryCommands>
                <AppBarButton x:ConnectionId='14' Label="Скопировать UIN"  Icon="Copy"                        />
                <AppBarButton x:ConnectionId='15' Label="Информация"        Icon="People"                          />
                <AppBarButton x:ConnectionId='16' Label="Переименовать"     Icon="Edit"                              />
                <AppBarButton x:ConnectionId='17' Label="Удалить контакт"   Icon="Delete"                            />
                <AppBarButton x:ConnectionId='18' Label="Очистить чат" Icon="Delete"                        />
            </CommandBar.SecondaryCommands>
        </CommandBar>
    </Page.BottomAppBar>
</Page>

