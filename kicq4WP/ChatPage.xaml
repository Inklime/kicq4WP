<Page
    x:Class="kicq4WP.ChatPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:kicq4WP"
    xmlns:gif="using:XamlAnimatedGif"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="#FF0D0D0D">

    <Page.Resources>
        <local:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <Style x:Key="EmojiButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontFamily" Value="Segoe WP"/>
            <Setter Property="Width" Value="56"/>
            <Setter Property="Height" Value="44"/>
            <Setter Property="Margin" Value="2"/>
        </Style>
    </Page.Resources>

    <!-- Корневая сетка. Row 4 добавлена под панель ввода (превью ответа), -->
    <!-- а поверх всего лежит RootOverlayGrid для попапов (переименование и т.п.) -->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="56"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Шапка -->
        <Border Grid.Row="0" Background="{StaticResource PhoneAccentBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="52"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                        Click="BackButton_Click"
                        Background="Transparent"
                        BorderThickness="0"
                        Width="52" Height="56" RenderTransformOrigin="0.176,0.56" Margin="-58,1,0,-3">
                    <TextBlock Text="         " FontFamily="Segoe UI Symbol"
                               FontSize="22" Foreground="White"
                               VerticalAlignment="Center" HorizontalAlignment="Center" Width="79"/>
                </Button>

                <Image Grid.Column="1"
                       x:Name="ContactStatusIcon"
                       Width="26" Height="26"
                       VerticalAlignment="Center"
                       Margin="0,0,8,0"/>

                <StackPanel Grid.Column="2" VerticalAlignment="Center" Margin="0,0,8,0">
                    <TextBlock x:Name="ContactNameTextBlock"
                               Text="Контакт"
                               FontSize="20"
                               FontFamily="Segoe WP"
                               Foreground="White"
                               TextTrimming="CharacterEllipsis"/>
                    <TextBlock x:Name="ContactUinTextBlock"
                               Text=""
                               FontSize="12"
                               FontFamily="Segoe WP"
                               Foreground="#CCFFFFFF"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Список сообщений -->
        <ListView x:Name="MessagesList"
                  Grid.Row="1"
                  Background="#FF0D0D0D"
                  SelectionMode="None"
                  IsItemClickEnabled="False"
                  Padding="6,4,6,4">
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    <Setter Property="Padding" Value="0"/>
                    <Setter Property="Margin" Value="0,2,0,2"/>
                    <Setter Property="Background" Value="Transparent"/>
                </Style>
            </ListView.ItemContainerStyle>
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Grid MinHeight="10">
                        <Border HorizontalAlignment="Left"
                MaxWidth="280"
                Background="#FF1E293B"
                Padding="10,7,10,7"
                Margin="0,0,50,0"
                Holding="MessageBorder_Holding"
                Visibility="{Binding IsIncoming, Converter={StaticResource BoolToVisibilityConverter}}">
                            <StackPanel>
                                <TextBlock Text="{Binding SenderName}"
                           FontSize="12"
                           FontFamily="Segoe WP"
                           Foreground="{StaticResource PhoneAccentBrush}"
                           Margin="0,0,0,2"/>

                                <RichTextBlock local:EmojiManager.FormattedText="{Binding Text}"
                               FontSize="17"
                               FontFamily="Segoe WP"
                               Foreground="White"
                               TextWrapping="Wrap"/>

                                <TextBlock Text="{Binding Time}"
                           FontSize="11"
                           FontFamily="Segoe WP"
                           Foreground="#88FFFFFF"
                           HorizontalAlignment="Right"
                           Margin="0,3,0,0"/>
                            </StackPanel>
                        </Border>

                        <Border HorizontalAlignment="Right"
                MaxWidth="280"
                Background="{StaticResource PhoneAccentBrush}"
                Padding="10,7,10,7"
                Margin="50,0,0,0"
                Holding="MessageBorder_Holding"
                Visibility="{Binding IsOutgoing, Converter={StaticResource BoolToVisibilityConverter}}">
                            <StackPanel>

                                <RichTextBlock local:EmojiManager.FormattedText="{Binding Text}"
                               FontSize="17"
                               FontFamily="Segoe WP"
                               Foreground="White"
                               TextWrapping="Wrap"/>

                                <TextBlock Text="{Binding Time}"
                           FontSize="11"
                           FontFamily="Segoe WP"
                           Foreground="#88FFFFFF"
                           HorizontalAlignment="Right"
                           Margin="0,3,0,0"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>


        <!-- Панель эмодзи -->
        <Border x:Name="EmojiPanel"
        Grid.Row="2"
        Background="#FF1A1A1A"
        Padding="4"
        Visibility="Collapsed">
            <GridView x:Name="EmojiItemsControl"
              Height="200"
              Background="#222222"
              SelectionMode="None"
              IsItemClickEnabled="True"
              ItemClick="OnEmojiPicked_GridView">
                <GridView.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapGrid Orientation="Horizontal"
                          MaximumRowsOrColumns="7"
                          ItemWidth="52"
                          ItemHeight="52"/>
                    </ItemsPanelTemplate>
                </GridView.ItemsPanel>
                <GridView.ItemContainerStyle>
                    <Style TargetType="GridViewItem">
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="Margin" Value="0"/>
                    </Style>
                </GridView.ItemContainerStyle>
                <GridView.ItemTemplate>
                    <DataTemplate>
                        <Border Width="48" Height="48" Background="Transparent">
                            <Image Source="{Binding ImagePath}"
                           Width="36" Height="36"
                           Stretch="Uniform"/>
                        </Border>
                    </DataTemplate>
                </GridView.ItemTemplate>
            </GridView>
        </Border>

        <!-- Панель "Ответить на сообщение" -->
        <Border x:Name="ReplyPreviewPanel"
                Grid.Row="3"
                Background="#FF232323"
                BorderBrush="{StaticResource PhoneAccentBrush}"
                BorderThickness="4,0,0,0"
                Padding="8,4,8,4"
                Visibility="Collapsed">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="ReplyPreviewText"
                           Grid.Column="0"
                           Foreground="#CCFFFFFF"
                           FontSize="14"
                           FontFamily="Segoe WP"
                           TextTrimming="CharacterEllipsis"
                           MaxLines="1"
                           VerticalAlignment="Center"/>
                <Button Grid.Column="1"
                        Content="✕"
                        Click="CancelReply_Click"
                        Background="Transparent"
                        BorderThickness="0"
                        Foreground="White"
                        FontSize="16"
                        Padding="10,4,4,4"/>
            </Grid>
        </Border>

        <!-- Панель ввода -->
        <Border Grid.Row="4" Background="#FF1A1A1A" Padding="6,6,6,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBox x:Name="MessageTextBox"
                         Style="{StaticResource ChatInputStyle}"
                         PlaceholderText="Сообщение..."
                         Margin="4,0,10.333,0"
                         VerticalAlignment="Bottom"
                         TextChanged="MessageTextBox_TextChanged"
                         KeyDown="MessageTextBox_KeyDown"
                         Grid.ColumnSpan="2"/>
                <MediaElement x:Name="SoundPlayer"
              Grid.Row="0" Grid.RowSpan="4"
              AutoPlay="False"
              Width="0" Height="0"/>
            </Grid>
        </Border>

        <!-- Полноэкранный оверлей для попапов (переименование и т.п.) -->
        <!-- Grid.RowSpan="5" — растягиваем на всю страницу, чтобы не зависеть -->
        <!-- от Popup и его смещений на разных DPI -->
        <Grid x:Name="RootOverlayGrid"
              Grid.RowSpan="5"
              Background="#99000000"
              Visibility="Collapsed">
        </Grid>
    </Grid>

    <Page.BottomAppBar>
        <CommandBar Background="{StaticResource PhoneAccentBrush}">
            <AppBarButton Icon="Send" Label="Отправить" Click="SendMessage_Click" Foreground="White"/>
            <AppBarButton Icon="Emoji2" Label="Смайлики" Click="EmojiButton_Click" Foreground="White"/>

            <CommandBar.SecondaryCommands>
            </CommandBar.SecondaryCommands>
        </CommandBar>
    </Page.BottomAppBar>
</Page>