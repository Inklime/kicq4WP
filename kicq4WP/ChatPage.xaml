<Page
    x:Class="kicq4WP.ChatPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:kicq4WP"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="#FF0D0D0D">

    <Page.Resources>
        <local:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <Style x:Key="EmojiButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontFamily" Value="Segoe WP"/>
            <Setter Property="Width" Value="56"/>
            <Setter Property="Height" Value="44"/>
            <Setter Property="Margin" Value="2"/>
        </Style>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="56"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Шапка -->
        <Border Grid.Row="0" Background="#FF0078D7">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="52"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                        Click="BackButton_Click"
                        Background="Transparent"
                        BorderThickness="0"
                        Width="52" Height="56" RenderTransformOrigin="0.176,0.56" Margin="-58,1,0,-3">
                    <TextBlock Text="         " FontFamily="Segoe UI Symbol"
                               FontSize="22" Foreground="White"
                               VerticalAlignment="Center" HorizontalAlignment="Center" Width="79"/>
                </Button>

                <Image Grid.Column="1"
                       x:Name="ContactStatusIcon"
                       Width="26" Height="26"
                       VerticalAlignment="Center"
                       Margin="0,0,8,0"/>

                <StackPanel Grid.Column="2" VerticalAlignment="Center" Margin="0,0,8,0">
                    <TextBlock x:Name="ContactNameTextBlock"
                               Text="Контакт"
                               FontSize="20"
                               FontFamily="Segoe WP"
                               Foreground="White"
                               TextTrimming="CharacterEllipsis"/>
                    <TextBlock x:Name="ContactUinTextBlock"
                               Text=""
                               FontSize="12"
                               FontFamily="Segoe WP"
                               Foreground="#CCFFFFFF"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Список сообщений -->
        <ListView x:Name="MessagesList"
                  Grid.Row="1"
                  Background="#FF0D0D0D"
                  SelectionMode="None"
                  IsItemClickEnabled="False"
                  Padding="6,4,6,4">
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    <Setter Property="Padding" Value="0"/>
                    <Setter Property="Margin" Value="0,2,0,2"/>
                    <Setter Property="Background" Value="Transparent"/>
                </Style>
            </ListView.ItemContainerStyle>
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Grid MinHeight="10">
                        <!-- Входящее — слева -->
                        <Border HorizontalAlignment="Left"
                                MaxWidth="280"
                                Background="#FF1E293B"
                                Padding="10,7,10,7"
                                Margin="0,0,50,0"
                                Visibility="{Binding IsIncoming, Converter={StaticResource BoolToVisibilityConverter}}">
                            <StackPanel>
                                <TextBlock Text="{Binding SenderName}"
                                           FontSize="12"
                                           FontFamily="Segoe WP"
                                           Foreground="#FF4FC3F7"
                                           Margin="0,0,0,2"/>
                                <TextBlock Text="{Binding Text}"
                                           FontSize="17"
                                           FontFamily="Segoe WP"
                                           Foreground="White"
                                           TextWrapping="Wrap"/>
                                <TextBlock Text="{Binding Time}"
                                           FontSize="11"
                                           FontFamily="Segoe WP"
                                           Foreground="#88FFFFFF"
                                           HorizontalAlignment="Right"
                                           Margin="0,3,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- Исходящее — справа -->
                        <Border HorizontalAlignment="Right"
                                MaxWidth="280"
                                Background="#FF004C97"
                                Padding="10,7,10,7"
                                Margin="50,0,0,0"
                                Visibility="{Binding IsOutgoing, Converter={StaticResource BoolToVisibilityConverter}}">
                            <StackPanel>
                                <TextBlock Text="{Binding Text}"
                                           FontSize="17"
                                           FontFamily="Segoe WP"
                                           Foreground="White"
                                           TextWrapping="Wrap"/>
                                <TextBlock Text="{Binding Time}"
                                           FontSize="11"
                                           FontFamily="Segoe WP"
                                           Foreground="#88FFFFFF"
                                           HorizontalAlignment="Right"
                                           Margin="0,3,0,0"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <!-- Панель эмодзи -->
        <Border x:Name="EmojiPanel"
                Grid.Row="2"
                Background="#FF1A1A1A"
                Padding="4"
                Visibility="Collapsed">
            <StackPanel>
                <StackPanel Orientation="Horizontal">
                    <Button Content=":-)" Click="InsertEmoji_Click" Tag=":-)" Style="{StaticResource EmojiButtonStyle}"/>
                    <Button Content=";-)" Click="InsertEmoji_Click" Tag=";-)" Style="{StaticResource EmojiButtonStyle}"/>
                    <Button Content=":-(" Click="InsertEmoji_Click" Tag=":-(" Style="{StaticResource EmojiButtonStyle}"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <Button Content="8-)" Click="InsertEmoji_Click" Tag="8-)" Style="{StaticResource EmojiButtonStyle}"/>
                    <Button Content=":-D" Click="InsertEmoji_Click" Tag=":-D" Style="{StaticResource EmojiButtonStyle}"/>
                    <Button Content="]:->" Click="InsertEmoji_Click" Tag="]:->" Style="{StaticResource EmojiButtonStyle}"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Панель ввода -->
        <Border Grid.Row="3" Background="#FF1A1A1A" Padding="6,6,6,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>



                <TextBox x:Name="MessageTextBox"
                         PlaceholderText="Сообщение..."
                         Background="#FF2A2A2A"
                         Foreground="White"
                         
                         BorderBrush="#FF555555"
                         BorderThickness="1"
                         Padding="10,8,10,8"
                         FontSize="17"
                         FontFamily="Segoe WP"
                         TextWrapping="Wrap"
                         MaxHeight="120"
                         VerticalAlignment="Bottom"
                         KeyDown="MessageTextBox_KeyDown" Grid.ColumnSpan="2" Margin="10,0,9.333,0"/>


            </Grid>
        </Border>
    </Grid>
    <Page.BottomAppBar>
        <CommandBar Background="#FF0078D7">
            <AppBarButton Icon="Send" Label="Отправить" Click="SendMessage_Click" Foreground="White"/>
            <AppBarButton Icon="Emoji2" Label="Смайлики" Click="EmojiButton_Click" Foreground="White"/>

            <CommandBar.SecondaryCommands>
                <AppBarButton Label="Очистить чат" Icon="Delete" Click="ClearChat_Click"/>
            </CommandBar.SecondaryCommands>
        </CommandBar>
    </Page.BottomAppBar>
</Page>
