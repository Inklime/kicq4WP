<Application
    x:Class="kicq4WP.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" RequestedTheme="Dark">
    <Application.Resources>
        <ResourceDictionary>
            <!-- Базовые цветовые ресурсы -->
            <SolidColorBrush x:Key="AppBackgroundBrush" Color="#FFFFFFFF"/>
            <SolidColorBrush x:Key="AppChromeBrush" Color="#FFF2F2F2"/>
            
            <!-- Стили шрифтов -->
            <x:Double x:Key="HeaderFontSize">28</x:Double>
            <x:Double x:Key="BodyFontSize">18</x:Double>

            <!-- Базовые стили для элементов управления -->
            <Style TargetType="Button" x:Key="AccentButtonStyle">
                <Setter Property="Background" Value="{StaticResource AppAccentBrush}"/>
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="Padding" Value="12,6"/>
                <Setter Property="Margin" Value="8"/>
                <Setter Property="HorizontalAlignment" Value="Center"/>
            </Style>
            <SolidColorBrush x:Key="AppAccentBrush"
                         Color="{StaticResource PhoneAccentColor}"/>

            <Style x:Key="ChatInputStyle" TargetType="TextBox">
                <Setter Property="Background" Value="White"/>
                <Setter Property="Foreground" Value="Black"/>
                <Setter Property="BorderBrush" 
                    Value="{StaticResource PhoneAccentBrush}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Padding" Value="8,8,8,8"/>
                <Setter Property="FontSize" Value="17"/>
                <Setter Property="FontFamily" Value="Segoe WP"/>
                <Setter Property="TextWrapping" Value="Wrap"/>
                <Setter Property="MaxHeight" Value="120"/>
                <Setter Property="SelectionHighlightColor" 
                    Value="{StaticResource PhoneAccentBrush}"/>
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>